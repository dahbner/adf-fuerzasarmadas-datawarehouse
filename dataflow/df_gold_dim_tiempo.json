{
	"name": "df_gold_dim_tiempo",
	"properties": {
		"folder": {
			"name": "gold"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "silver_movimientos_personal",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "gold_dim_tiempo",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [],
			"scriptLines": [
				"source(output(",
				"          fecha_key as integer,",
				"          fecha as date,",
				"          dia_semana as integer,",
				"          nombre_dia as string,",
				"          dia_mes as integer,",
				"          mes as integer,",
				"          nombre_mes as string,",
				"          trimestre as integer,",
				"          anio as integer,",
				"          es_fin_semana as boolean",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     query: 'SELECT \\n    CAST(CONVERT(VARCHAR(8), fecha, 112) AS INT) AS fecha_key,\\n    fecha,\\n    DATEPART(WEEKDAY, fecha) AS dia_semana,\\n    DATENAME(WEEKDAY, fecha) AS nombre_dia,\\n    DAY(fecha) AS dia_mes,\\n    MONTH(fecha) AS mes,\\n    DATENAME(MONTH, fecha) AS nombre_mes,\\n    DATEPART(QUARTER, fecha) AS trimestre,\\n    YEAR(fecha) AS anio,\\n    CAST(CASE WHEN DATEPART(WEEKDAY, fecha) IN (6, 7) THEN 1 ELSE 0 END AS BIT) AS es_fin_semana\\nFROM (\\n    SELECT CAST(fecha_inicio AS DATE) AS fecha FROM silver.operaciones WHERE fecha_inicio IS NOT NULL\\n    UNION\\n    SELECT CAST(fecha_fin AS DATE) FROM silver.operaciones WHERE fecha_fin IS NOT NULL\\n    UNION\\n    SELECT CAST(fecha_movimiento AS DATE) FROM silver.movimientos_personal WHERE fecha_movimiento IS NOT NULL\\n) t',",
				"     format: 'query') ~> source1",
				"source1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          fecha_key as integer,",
				"          fecha as date,",
				"          dia_semana as integer,",
				"          nombre_dia as string,",
				"          dia_mes as integer,",
				"          mes as integer,",
				"          nombre_mes as string,",
				"          trimestre as integer,",
				"          anio as integer,",
				"          es_fin_semana as boolean",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     truncate:true,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          fecha_key,",
				"          fecha,",
				"          dia_semana,",
				"          nombre_dia,",
				"          dia_mes,",
				"          mes,",
				"          nombre_mes,",
				"          trimestre,",
				"          anio,",
				"          es_fin_semana",
				"     )) ~> sink1"
			]
		}
	}
}
{
	"name": "df_silver_zonas",
	"properties": {
		"folder": {
			"name": "silver"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "bronze_zonas",
						"type": "DatasetReference"
					},
					"name": "bronzeZonas"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "silver_zonas",
						"type": "DatasetReference"
					},
					"name": "silverZonas"
				}
			],
			"transformations": [
				{
					"name": "derivedColumn1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          id_zona as string,",
				"          nombre as string,",
				"          departamento as string,",
				"          frontera_con as string,",
				"          tipo_terreno as string,",
				"          altitud_msnm as string,",
				"          acceso_carretero as string,",
				"          nivel_riesgo as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> bronzeZonas",
				"bronzeZonas derive(id_zona = toInteger(id_zona),",
				"          nombre = trim(regexReplace(nombre, '\\\\s+', ' ')),",
				"          departamento = initCap(trim(regexReplace(departamento, '\\\\s+', ' '))),",
				"          frontera_con = iif(isNull(frontera_con) || lower(trim(frontera_con)) == 'null' || trim(frontera_con) == '', 'Ninguna', trim(regexReplace(frontera_con, '\\\\s+', ' '))),",
				"          tipo_terreno = initCap(trim(regexReplace(tipo_terreno, '\\\\s+', ' '))),",
				"          altitud_msnm = toInteger(altitud_msnm),",
				"          acceso_carretero = iif(lower(trim(acceso_carretero)) == 'true', 'Sí', 'No'),",
				"          nivel_riesgo = initCap(trim(regexReplace(nivel_riesgo, '\\\\s+', ' ')))) ~> derivedColumn1",
				"derivedColumn1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          id_zona as integer,",
				"          nombre as string,",
				"          departamento as string,",
				"          frontera_con as string,",
				"          tipo_terreno as string,",
				"          altitud_msnm as integer,",
				"          acceso_carretero as string,",
				"          nivel_riesgo as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     truncate:true,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          id_zona,",
				"          nombre,",
				"          departamento,",
				"          frontera_con,",
				"          tipo_terreno,",
				"          altitud_msnm,",
				"          acceso_carretero,",
				"          nivel_riesgo",
				"     )) ~> silverZonas"
			]
		}
	}
}
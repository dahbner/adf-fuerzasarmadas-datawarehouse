{
	"name": "df_silver_tipos_operacion",
	"properties": {
		"folder": {
			"name": "silver"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "bronze_tipos_operacion",
						"type": "DatasetReference"
					},
					"name": "bronzeTiposOperacion"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "silver_tipos_operacion",
						"type": "DatasetReference"
					},
					"name": "silverTiposOperacion"
				}
			],
			"transformations": [
				{
					"name": "derivedColumn1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          id_tipo as string,",
				"          nombre as string,",
				"          categoria as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> bronzeTiposOperacion",
				"bronzeTiposOperacion derive(id_tipo = toInteger(id_tipo),",
				"          nombre = initCap(trim(nombre)),",
				"          categoria = initCap(replace(trim(categoria), '_', ' '))) ~> derivedColumn1",
				"derivedColumn1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          id_tipo as integer,",
				"          nombre as string,",
				"          categoria as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     truncate:true,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          id_tipo,",
				"          nombre,",
				"          categoria",
				"     )) ~> silverTiposOperacion"
			]
		}
	}
}